{
  "name": "vue-video-ambilight",
  "author": "Yohann Marchand",
  "version": "1.1.0",
  "description": "Vue 3 component that adds an ambilight glow effect around a video",
  "keywords": [
    "vue",
    "vue3",
    "video",
    "ambilight",
    "component"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yohannmarchand/vue-video-ambilight"
  },
  "homepage": "https://github.com/yohannmarchand/vue-video-ambilight#readme",
  "bugs": {
    "url": "https://github.com/yohannmarchand/vue-video-ambilight/issues"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/vue-video-ambilight.umd.cjs",
  "module": "./dist/vue-video-ambilight.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-video-ambilight.js",
      "require": "./dist/vue-video-ambilight.umd.cjs"
    }
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "vite build",
    "build:storybook": "storybook build",
    "type-check": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.0.0",
    "@storybook/addon-interactions": "^8.0.0",
    "@storybook/vue3-vite": "^8.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "storybook": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vue": "^3.5.0",
    "vite-plugin-dts": "^4.0.0",
    "vue-tsc": "^2.0.0"
  }
}
